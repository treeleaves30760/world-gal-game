# Python-generated files
__pycache__/
*.py[oc]
build/
build/web/
dist/
wheels/
*.egg-info

# Steam: the dev-supplied appid marker for local testing (never committed).
# The steam_api redistributable itself is covered by the *.dll/*.so/*.dylib
# rules below.
steam_appid.txt

# Virtual environments
.venv

# pygame-ce / SDL
*.dll
*.dylib
*.so

# user / runtime artefacts (ad-hoc test screenshots & saves)
screenshots/
saves/
qa_shots/
tmp/
*.save.json
QA_REPORT*.md

# pytest / build caches
.pytest_cache/
*.bak

# PyInstaller build artefacts
*.spec.bak

# editor leftovers
.DS_Store
.vscode/
.idea/

# codex temp output (the wrapper moves files but logs may linger)
.codex_cache/

# OS image caches under games/<pack>/assets — keep, they're game content

# Docusaurus docs site (Node tooling lives at repo root; docs content is docs/).
# Build output goes to site/ (not build/, which PyInstaller uses).
node_modules/
/site/
.docusaurus/
.cache-loader/
